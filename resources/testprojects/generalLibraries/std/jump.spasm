@define jmp(label) {
  ; destroys mo, r14, r15
  movi r14, [label & 0xffff]         ; low half
  movi r15, [(label << 16) & 0xffff] ; high half
  mov  mol, r14
  mov  moh, r15
  jmpr mo
}
@define jmps(label) {
  ; saves registers
  push r14
  push r15
  push mol
  push moh

  jmp label

  pop moh
  pop mol
  pop r15
  pop r14
  
}