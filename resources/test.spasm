; @include "include.spasm" 
@define rF r15
@define rF r13
@define mul32(rA,rB,rC,rD,rdA,rdB) {
  push rF
  mull rdA, rC, rA
  mulh rdB, rC, rA

  mull rF, rB, rD
  add  rdB, rF, rdB
  pop rF
}

; syntax test file
movi r2, 56
movi r3, 84
add r1, r2, r3
sub r1, r2, r3
adi r2, r2, [20389 * 2 + 65 - 25 - 2 * 252 + main]

main:
movi r2, 0
mul32 r1, r2, r3, r4, r5, r6
nop
nop
nop
add r4, r2, r4
; BYTE hello, 10

helper:
helper.main:
; TEXT helper.main.text, AUTO, "Hello World!"